# .env
# Paga Business API Keys for NeXa Esports
# Get your credentials from https://developer.paga.com/
PAGA_PUBLIC_KEY=your_paga_public_key_here
PAGA_HASH_KEY=your_paga_hash_key_here
PAGA_BASE_URL=https://www.mypaga.com
PAGA_ORGANIZATION_NAME=NeXa Esports
# Set to true to use the Paga sandbox (beta.mypaga.com) instead of production
PAGA_IS_SANDBOX=false

# Flutterwave v3 API Keys (deprecated — kept for reference during transition)
# FLW_PUBLIC_KEY=your_flutterwave_public_key_here
# FLW_SECRET_KEY=your_flutterwave_secret_key_here
# FLW_ENCRYPTION_KEY=your_flutterwave_encryption_key_here
# FLW_WEBHOOK_SECRET=your_webhook_secret_here

# Environment
ENVIRONMENT=development

# VAPID Keys for Web Push Notifications (PWA/Web)
# Generate your own keys using: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY is used by the frontend (Vite)
# VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, and VAPID_EMAIL are used by Supabase Edge Functions
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com

# Firebase Cloud Messaging (FCM) Configuration
# Get these from your Firebase project settings: https://console.firebase.google.com/
# Frontend variables (used by Vite - prefix with VITE_)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_firebase_vapid_key_here

# Backend variables for Supabase Edge Functions (FCM v1 API)
# Get these from Firebase Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# VTPass API Configuration
# Get your credentials from https://www.vtpass.com/
# VTPass is used for airtime and data purchases
VTPASS_API_KEY=your_vtpass_api_key_here
VTPASS_SECRET_KEY=your_vtpass_secret_key_here
VTPASS_PUBLIC_KEY=your_vtpass_public_key_here

# Resend API Configuration
RESEND_API_KEY=re_123456789
RESEND_SENDER_EMAIL=notifications@nexaesports.com
RESEND_SENDER_NAME="NeXa Esports"
