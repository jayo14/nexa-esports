# .env
# Flutterwave Live API Keys for Nexaesport
# Note: Live accounts use CLIENT_ID instead of PUBLIC_KEY for server-side authentication
FLUTTERWAVE_CLIENT_ID=your_flutterwave_client_id_here
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key_here
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_here

# Environment
ENVIRONMENT=development

# VAPID Keys for Web Push Notifications
# Generate your own keys using: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY is used by the frontend (Vite)
# VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, and VAPID_EMAIL are used by Supabase Edge Functions
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com
